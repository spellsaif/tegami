{
  "name": "@tegami/core",
  "version": "0.0.0",
  "description": "Utility for package versioning & publish",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/tegami",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./generators/simple": "./dist/generators/simple.mjs",
    "./plugins/github": "./dist/plugins/github.mjs",
    "./registry": "./dist/registry/index.mjs",
    "./registry/npm": "./dist/registry/npm.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "js-yaml": "^4.2.0",
    "mdast-util-to-markdown": "^2.1.2",
    "package-manager-detector": "^1.6.0",
    "remark": "^15.0.1",
    "semver": "^7.8.4",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "tsdown": "^0.22.2",
    "typescript": "6.0.3"
  }
}
